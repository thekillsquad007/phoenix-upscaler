# Gumroad OAuth app (from gumroad.com → Settings → Advanced → Applications)
GUMROAD_APP_ID=your_app_id
GUMROAD_APP_SECRET=your_app_secret
GUMROAD_REDIRECT_URI=http://127.0.0.1:8741/api/oauth/gumroad/callback
# Filled automatically after: python scripts/gumroad_connect.py
GUMROAD_ACCESS_TOKEN=

PHOENIX_GUMROAD_PRODUCT_ID=
PHOENIX_GUMROAD_PRODUCT_URL=https://aravindk74.gumroad.com/l/phoenixupscaler
PHOENIX_PRICE_USD=6
PHOENIX_WEBSITE_URL=https://aravindk74.github.io/phoenix-upscaler/
PHOENIX_LICENSE_SECRET=change-me-to-a-long-random-string

# Automated license-key emails — run: python scripts/setup_free_email.py
# Brevo (recommended, 300/day free): https://www.brevo.com
BREVO_API_KEY=
PHOENIX_EMAIL_FROM=aravindkishore21@gmail.com
PHOENIX_EMAIL_FROM_NAME=Phoenix Upscaler
PHOENIX_EMAIL_PROVIDER=brevo
# Alternatives:
SENDGRID_API_KEY=
RESEND_API_KEY=
# Gmail SMTP (also free): https://myaccount.google.com/apppasswords
PHOENIX_SMTP_HOST=
PHOENIX_SMTP_PORT=587
PHOENIX_SMTP_USER=
PHOENIX_SMTP_PASSWORD=

# Optional public URL for Gumroad Ping webhook (ngrok/cloudflare tunnel)
PHOENIX_PUBLIC_URL=
PHOENIX_GUMROAD_POLL_SEC=300